-- Función para crear botones con colores
local function CreateButton(text, color, posX, toggleVar)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 105, 0, 45)
    btn.Position = UDim2.new(0, posX, 0, 10)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = TopBar

    btn.MouseButton1Click:Connect(function()
        toggleVar = not toggleVar
        btn.BackgroundColor3 = toggleVar and color or Color3.fromRGB(80, 80, 80)
        btn.Text = text .. (toggleVar and " ✓" or " ✕")
    end)
    return btn
end

